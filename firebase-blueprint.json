{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Schema representing a single track booking/reservation at Rix Compound",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique booking reference ID"
        },
        "name": {
          "type": "string",
          "description": "Full name of the rider"
        },
        "email": {
          "type": "string",
          "description": "Contact email address"
        },
        "phone": {
          "type": "string",
          "description": "Contact mobile/whatsapp number"
        },
        "date": {
          "type": "string",
          "description": "Booking date in YYYY-MM-DD format"
        },
        "slot": {
          "type": "string",
          "description": "Selected time slot"
        },
        "bikeType": {
          "type": "string",
          "description": "Type of bike rented (PitBike, QuadBike, GroupPackage, Mixed)"
        },
        "packageName": {
          "type": "string",
          "description": "Name of the rental/own bike package"
        },
        "quantity": {
          "type": "integer",
          "description": "Number of units rented"
        },
        "pitBikeQty": {
          "type": "integer",
          "description": "Count of pit bikes rented in mixed package"
        },
        "quadBikeQty": {
          "type": "integer",
          "description": "Count of quad bikes rented in mixed package"
        },
        "amount": {
          "type": "number",
          "description": "Total price paid/payable"
        },
        "paid": {
          "type": "boolean",
          "description": "Payment status flag"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of booking creation"
        }
      },
      "required": ["id", "name", "email", "phone", "date", "slot", "bikeType", "quantity", "amount", "paid"]
    },
    "ClosedDate": {
      "title": "ClosedDate",
      "description": "Schema representing a date closed by the admin to prevent bookings",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "description": "Closed date in YYYY-MM-DD format"
        },
        "reason": {
          "type": "string",
          "description": "Optional reason for closure"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of closure creation"
        }
      },
      "required": ["date"]
    },
    "ClosedSlot": {
      "title": "ClosedSlot",
      "description": "Schema representing a specific 45-minute riding slot closed by the admin",
      "type": "object",
      "properties": {
        "date": {
          "type": "string",
          "description": "Closed date in YYYY-MM-DD format"
        },
        "slot": {
          "type": "string",
          "description": "Closed time slot"
        },
        "reason": {
          "type": "string",
          "description": "Optional reason for closure"
        },
        "createdAt": {
          "type": "string",
          "description": "ISO timestamp of closure creation"
        }
      },
      "required": ["date", "slot"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of all user track bookings and rentals"
    },
    "/closed_dates/{date}": {
      "schema": "ClosedDate",
      "description": "Collection of dates that are closed for bookings"
    },
    "/closed_slots/{slotId}": {
      "schema": "ClosedSlot",
      "description": "Collection of specific time slots closed for bookings"
    }
  }
}
