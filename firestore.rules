rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Bookings collection
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isValidBooking(request.resource.data);
      allow delete: if true;
      allow update: if isValidBooking(request.resource.data);
    }

    // Mail outbox collection for Trigger Email extension
    match /mail/{mailId} {
      allow read: if false;
      allow create: if isValidMail(request.resource.data);
      allow delete: if false;
      allow update: if false;
    }

    function isValidMail(data) {
      return data.keys().hasAll(['to', 'message'])
        && data.to is string
        && data.message is map
        && data.message.keys().hasAll(['subject', 'html'])
        && data.message.subject is string
        && data.message.html is string;
    }
    
    // Standalone validation helper function
    function isValidBooking(data) {
      return data.keys().hasAll(['date', 'timeSlot', 'type', 'packageName', 'name', 'email', 'phone', 'bikes', 'totalPaid', 'createdAt', 'paid'])
        && data.date is string
        && data.timeSlot is string
        && data.type is string && (data.type == 'individual' || data.type == 'group')
        && data.packageName is string
        && data.name is string
        && data.email is string
        && data.phone is string
        && (data.totalPaid is int || data.totalPaid is float)
        && data.createdAt is string
        && data.paid is bool
        && data.bikes is map
        && data.bikes.keys().hasAll(['pitBikes', 'quads', 'ownBikes'])
        && (data.bikes.pitBikes is int || data.bikes.pitBikes is float)
        && (data.bikes.quads is int || data.bikes.quads is float)
        && (data.bikes.ownBikes is int || data.bikes.ownBikes is float);
    }
  }
}
